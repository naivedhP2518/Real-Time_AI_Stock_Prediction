# ============================================================
# client/.gitignore — Vite + React Frontend
# ============================================================

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Dependencies & Build Outputs ─────────────────────────────
node_modules/
dist/
dist-ssr/
.cache/

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.example
*.env

# ── TypeScript / Vite cache ───────────────────────────────────
*.tsbuildinfo
vite.config.js.timestamp-*

# ── Testing & Coverage ────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Editor & OS ───────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
