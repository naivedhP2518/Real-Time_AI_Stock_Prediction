# ============================================================
# server/.gitignore — Express.js Backend
# ============================================================

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Environment & Secrets (NEVER commit) ──────────────────────
.env
.env.*
!.env.example
*.env
*.pem
*.key
*.cert

# ── Database files ────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
data/db/

# ── Build Outputs ─────────────────────────────────────────────
dist/
build/

# ── Testing & Coverage ────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.jest-cache/

# ── Editor & OS ───────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
