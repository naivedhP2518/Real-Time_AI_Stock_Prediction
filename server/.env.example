# ═══════════════════════════════════════════════════════
# Real-Time AI Stock Prediction Platform — .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────
# Local:      mongodb://localhost:27017/stock-prediction
# Atlas:      mongodb+srv://<user>:<pass>@cluster.mongodb.net/stock-prediction
MONGO_URI=mongodb://localhost:27017/stock-prediction

# ─── JWT Authentication ───────────────────────────────
# Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
JWT_EXPIRES_IN=30d

# ─── Redis Cache (Optional — app degrades gracefully without it) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Stock Market APIs ────────────────────────────────
# Finnhub: https://finnhub.io/dashboard
FINNHUB_API_KEY=your_finnhub_api_key_here

# ─── ML Microservice ─────────────────────────────────
ML_SERVICE_URL=http://localhost:5001

# ─── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (production only)
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ─── Docker (used in docker-compose) ─────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_strong_password
VITE_API_URL=http://localhost:5000
VITE_ML_URL=http://localhost:5001

# ─── Deployment (CI/CD secrets — set in GitHub Actions) ──
# DEPLOY_HOST=your.server.ip
# DEPLOY_USER=ubuntu
# DEPLOY_SSH_KEY=(set via GitHub Secrets)
# PRODUCTION_URL=https://yourdomain.com
